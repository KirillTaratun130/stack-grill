# Copy this file to .env and fill in your real connection string.
# .env is git-ignored; .env.example is committed — keep ONLY placeholders here.
#
# Prisma does NOT auto-load .env in Prisma 7. It is loaded via
# `import "dotenv/config"` in prisma.config.ts (already configured).
#
# Connection string format: https://pris.ly/d/connection-strings

# For the local Docker Postgres (`pnpm db:up`), the default compose
# credentials are postgres/postgres — this URL works out of the box:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stack_grill?schema=public"
